---
import { type CollectionEntry } from "astro:content";
import { marked } from "marked";
import Layout from "@/layouts/Layout.astro";
import RelatedPosts from "@/components/RelatedPosts.astro";
import { getPath } from "@/utils/getPath";
import { getRelatedPosts } from "@/utils/getRelatedPosts";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";
import { SHARE_LINKS } from "@/constants";
import { buildBlogPostingJsonLd } from "@/utils/structuredData";
import { toAbsoluteSiteUrl, toPostUrl } from "@/utils/url";

export interface Props {
  post: CollectionEntry<"liveBlog">;
  posts: CollectionEntry<"liveBlog">[];
}

const { post, posts } = Astro.props;
const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
  hideEditPost,
} = post.data;
const htmlContent = await marked.parse(post.body || "");
let ogImageUrl: string | undefined;
if (typeof initOgImage === "string") ogImageUrl = initOgImage;
else if (initOgImage?.src) ogImageUrl = initOgImage.src;
if (!ogImageUrl && SITE.dynamicOgImage)
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
const ogImage = ogImageUrl
  ? toAbsoluteSiteUrl(ogImageUrl, SITE.website)
  : undefined;
const postUrl = canonicalURL
  ? toAbsoluteSiteUrl(canonicalURL, SITE.website, { trailingSlash: true })
  : toPostUrl(getPath(post.id, post.filePath), SITE.website);
const jsonLd = buildBlogPostingJsonLd({
  title,
  description,
  url: postUrl,
  image: ogImage,
  author: author ?? SITE.author,
  authorUrl: SITE.profile,
  pubDatetime,
  modDatetime,
  tags,
});
const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));
const currentPostIndex = allPosts.findIndex(a => a.id === post.id);
const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex >= 0 && currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;
const relatedPosts = getRelatedPosts(post, posts);
const wordCount = (post.body || "").trim().split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(wordCount / 220));
const postTags = tags ?? [];
const lane = postTags[0] ?? "agentic-dev";
const formatDate = (value: Date | string | undefined | null) => {
  if (!value) return undefined;
  const date = value instanceof Date ? value : new Date(value);
  return Number.isNaN(date.getTime())
    ? String(value).slice(0, 10)
    : date.toISOString().slice(0, 10);
};
const toc = Array.from((post.body || "").matchAll(/^##\s+(.+)$/gm))
  .map(match => String(match[1]).replace(/#+$/, "").trim())
  .filter(Boolean)
  .slice(0, 8)
  .map(label => ({ label, href: `#${slugifyStr(label)}` }));
const published = formatDate(pubDatetime) ?? "pending";
const updated = formatDate(modDatetime) ?? published;
const footerShareLinks = SHARE_LINKS.map(social => ({
  ...social,
  href: `${social.href}${encodeURIComponent(postUrl)}`,
}));
const editPostHref = `${SITE.editPost.url}${post.filePath}`;
const showEditPost = SITE.editPost.enabled && !hideEditPost;
const tagSummary = postTags.length > 0 ? postTags.join(", ") : "untagged";
const primaryTagHref =
  postTags.length > 0 ? `/tags/${slugifyStr(postTags[0])}/` : "/tags/";
const primaryShareHref = footerShareLinks[0]?.href ?? postUrl;
---

<Layout
  title={`${title} | ${SITE.title}`}
  author={author}
  description={description}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
  canonicalURL={postUrl}
  ogImage={ogImage}
  scrollSmooth={true}
  jsonLd={jsonLd}
>
  <div class="progress" id="progress" aria-hidden="true"></div>
  <div class="window proto-window" data-pagefind-body>
    <div class="titlebar">
      <button class="hamb" aria-label="Menu" type="button">&#9776;</button><span
        class="path"
        >m@berryhill: ~/berryhill.dev/posts/<b>{post.id}.md</b></span
      ><span class="gnome-ctrls"
        ><button class="gctl min" aria-label="Minimize" type="button"
          >&minus;</button
        ><button class="gctl max" aria-label="Maximize" type="button"
          >&#9633;</button
        ><button class="gctl cls" aria-label="Close" type="button"
          >&times;</button
        ></span
      >
    </div>
    <div class="tabstrip">
      <a class="tab" href="/">~ home</a><a class="tab on" href="/posts/"
        >posts/</a
      ><a class="tab" href="/about/">about.md</a><span
        class="tabnew"
        aria-hidden="true">+</span
      >
    </div>
    <div class="term">
      <div class="line">
        <span class="ps1"
          >m@berryhill <span class="sep">in</span>
          <span class="cwd">~/posts</span></span
        ><span class="cmd">$ cat {post.id}.md</span>
      </div>
      <pre
        class="frontmatter"><span class="sep">---</span>
<span class="k">title</span>:  <span class="v">{title}</span>
<span class="k">date</span>:   <span class="v">{published}</span>
<span class="k">topic</span>:  <span class="v inf">{lane}</span>
<span class="k">read</span>:   <span class="v acc">{readMinutes} min</span>
<span class="k">words</span>:  <span class="v dim">{wordCount.toLocaleString()}</span>
<span class="k">slug</span>:   <span class="v dim">{post.id}</span>
<span class="k">views</span>:  <span class="v dim">live post</span>
<span class="k">tags</span>:   <span class="v inf">[{postTags.join(", ")}]</span>
<span class="sep">---</span></pre>
      <article>
        <header class="post-head">
          <div class="kicker">essay · long read</div>
          <h1 transition:name={slugifyStr(title)}>{title}</h1>
          <p class="deck">{description}</p>
          <div class="bylines">
            <div class="item">
              <span class="lbl">by</span>
              <b>matthew berryhill</b>
            </div><span class="dot">·</span><div class="item">
              <span class="lbl">posted</span>
              <b>{published}</b>
            </div><span class="dot">·</span><div class="item">
              <span class="lbl">updated</span>
              <b>{updated}</b>
            </div><span class="dot">·</span><div class="item">
              <span class="lbl">topic</span>
              <a href={`/tags/${slugifyStr(lane)}/`}>{lane}</a>
            </div>
          </div>
        </header>
        {
          toc.length > 0 && (
            <details class="toc-inline">
              <>
                <summary>table of contents</summary>
                <ol>
                  {toc.map(item => (
                    <li>
                      <a href={item.href}>{item.label}</a>
                    </li>
                  ))}
                </ol>
              </>
            </details>
          )
        }
        <div class="post-layout">
          {
            toc.length > 0 && (
              <aside class="toc" data-pagefind-ignore>
                <>
                  <div class="toc-title"># on this page</div>
                  <ol id="toc-list">
                    {toc.map((item, index) => (
                      <li class:list={{ active: index === 0 }}>
                        <a href={item.href}>{item.label}</a>
                      </li>
                    ))}
                  </ol>
                </>
              </aside>
            )
          }
          <div class="post-body astro-post-content" set:html={htmlContent} />
        </div>
        <div class="block-h" data-pagefind-ignore>
          <h2>cat post.meta</h2>
          <span class="n">reader actions</span>
        </div>
        <div
          class="env post-actions"
          aria-label="post footer reader actions"
          data-pagefind-ignore
        >
          <a href={primaryTagHref} aria-label={`post tags: ${tagSummary}`}>
            <span><b>TAGS=</b> [{tagSummary}]</span>
            <span>open →</span>
          </a>
          <a
            href={primaryShareHref}
            title="Share this post"
            rel="noopener noreferrer"
            aria-label="share this post"
          >
            <span><b>SHARE=</b> {post.id}</span>
            <span>send →</span>
          </a>
          {
            showEditPost ? (
              <a
                href={editPostHref}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="edit this post"
              >
                <span>
                  <b>EDIT=</b> source
                </span>
                <span>patch →</span>
              </a>
            ) : (
              <span
                class="env-disabled"
                aria-label="edit this post unavailable"
              >
                <span>
                  <b>EDIT=</b> source
                </span>
                <span>disabled</span>
              </span>
            )
          }
          <button
            type="button"
            aria-label="post operations: scroll to top"
            data-terminal-top
          >
            <span><b>TOP=</b> scroll</span>
            <span>top ↑</span>
          </button>
        </div>
        <div class="line end-prompt">
          <span class="ps1"
            >m@berryhill <span class="sep">in</span>
            <span class="cwd">~/posts</span></span
          ><span class="cmd">$ </span><span
            class="terminal-cursor"
            aria-hidden="true"></span>
        </div>
        <nav class="adjacent" aria-label="adjacent posts" data-pagefind-ignore>
          {
            prevPost && (
              <a
                class="adj prev"
                href={getPath(prevPost.id, prevPost.filePath)}
              >
                <>
                  <span class="lbl">
                    <span class="arr">←</span> prev
                  </span>
                  <span class="ttl">{prevPost.title}</span>
                  <span class="meta">
                    topic: <b>post</b>
                  </span>
                </>
              </a>
            )
          }{
            nextPost && (
              <a
                class="adj next"
                href={getPath(nextPost.id, nextPost.filePath)}
              >
                <>
                  <span class="lbl">
                    next <span class="arr">→</span>
                  </span>
                  <span class="ttl">{nextPost.title}</span>
                  <span class="meta">
                    topic: <b>post</b>
                  </span>
                </>
              </a>
            )
          }
        </nav>
        <a class="back" href="/posts/"
          ><span class="ps">$</span> cd ../ <span style="color: var(--dim)"
            >· back to posts/</span
          ></a
        >
      </article>
    </div>
  </div>
  <div class="window proto-window" data-pagefind-ignore>
    <div class="term"><RelatedPosts posts={relatedPosts} /></div>
  </div>
</Layout>

<script is:inline>
  const bar = document.getElementById("progress");
  function tickProgress() {
    if (!bar) return;
    const h = document.documentElement;
    const max = h.scrollHeight - h.clientHeight;
    const pct = max <= 0 ? 0 : (h.scrollTop / max) * 100;
    bar.style.width = pct + "%";
  }
  window.addEventListener("scroll", tickProgress, { passive: true });
  window.addEventListener("resize", tickProgress);
  tickProgress();

  document.querySelectorAll("[data-terminal-top]").forEach(button => {
    button.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  });
</script>
