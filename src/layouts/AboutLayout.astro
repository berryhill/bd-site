---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";
import { buildPersonJsonLd } from "@/utils/structuredData";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
const jsonLd = buildPersonJsonLd({
  name: SITE.author,
  url: SITE.profile,
  image: new URL("/matt_headshot.jpeg", SITE.website).href,
  description: frontmatter.description ?? SITE.desc,
});
---

<Layout title={`${frontmatter.title} | ${SITE.title}`} jsonLd={jsonLd}>
  <Header />
  <Breadcrumb />
  <main id="main-content">
    <section
      id="about"
      class="app-prose mx-auto mb-28 max-w-app px-4 prose-img:border-0"
    >
      <h1 class="mb-8 text-2xl tracking-wider sm:text-3xl">
        {frontmatter.title}
      </h1>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
