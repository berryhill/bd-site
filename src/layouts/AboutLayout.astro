---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";
import { buildPersonJsonLd } from "@/utils/structuredData";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
const jsonLd = buildPersonJsonLd({
  name: SITE.author,
  url: SITE.profile,
  image: new URL("/matt_headshot.jpeg", SITE.website).href,
  description: frontmatter.description ?? SITE.desc,
});
---

<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  description={frontmatter.description ?? SITE.desc}
  jsonLd={jsonLd}
>
  <Header />
  <main id="main-content" class="terminal-page px-4 pb-16 sm:px-6">
    <section
      id="about"
      class="app-prose terminal-prose-shell mx-auto mt-8 mb-12 max-w-5xl prose-img:border-0"
    >
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
